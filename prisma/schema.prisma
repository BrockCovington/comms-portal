generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// NextAuth / Auth.js adapter models (database session strategy).
// Shapes below match @auth/prisma-adapter. Don't rename these fields.
// ---------------------------------------------------------------------------

enum Role {
  EMPLOYEE
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EMPLOYEE)
  createdAt     DateTime  @default(now())

  // The user's chosen quick-reaction emoji for huddles (unicode graphemes or
  // ":name:" custom-emoji tokens). Empty = fall back to the default set.
  huddleReactions String[] @default([])

  // Custom status (Slack-style): an emoji token + short text, optionally
  // auto-clearing at statusExpiresAt (null = don't clear). Treated as inactive
  // once expired (resolved at read/render time — no cron needed).
  statusEmoji     String?
  statusText      String?
  statusExpiresAt DateTime?

  // Custom (uploaded) profile picture. When set, `image` holds the
  // access-checked proxy path (GET /api/users/:id/avatar); the fields below
  // are server-only Blob bookkeeping the proxy uses to stream the bytes and
  // clean up on replace/remove. `oauthImage` preserves the original OAuth
  // (Google) picture so removing a custom one falls back to it, not to blank.
  avatarBlobUrl  String?
  avatarBlobPath String?
  avatarMimeType String?
  oauthImage     String?

  accounts        Account[]
  sessions        Session[]
  memberships     ChannelMember[]
  messages        Message[]
  createdChannels Channel[]       @relation("ChannelCreator")
  channelReads    ChannelRead[]
  threadReads     ThreadRead[]
  reactions       Reaction[]
  attachments     Attachment[]

  notifications           Notification[]
  triggeredNotifications  Notification[] @relation("NotificationActor")
  drafts                  Draft[]
  starredChannels         StarredChannel[]
  savedMessages           SavedMessage[]
  pinnedMessages          PinnedMessage[]
  createdEmoji            CustomEmoji[]
  notificationPreference  NotificationPreference?
  channelPreferences      ChannelPreference[]
  channelSections         ChannelSection[]
  scheduledMessages       ScheduledMessage[]
  canvases                Canvas[]
  createdLists            List[]             @relation("CreatedLists")
  assignedListItems       ListItem[]         @relation("AssignedItems")
  createdWorkflows        Workflow[]         @relation("CreatedWorkflows")
  reminders               Reminder[]
  channelBookmarks        ChannelBookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Chat domain models
// ---------------------------------------------------------------------------

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false) // private channels require membership
  isDm        Boolean  @default(false) // direct messages between members
  dmKey       String?  @unique // sorted "userIdA:userIdB", set only for isDm channels
  archivedAt  DateTime? // null = active; set = frozen (read-only), see /archive route
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   User?    @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: SetNull)

  members       ChannelMember[]
  messages      Message[]
  channelReads  ChannelRead[]
  attachments   Attachment[]
  notifications Notification[]
  drafts        Draft[]
  starredBy     StarredChannel[]
  pinnedMessages PinnedMessage[]
  preferences   ChannelPreference[]
  scheduledMessages ScheduledMessage[]
  workflows     Workflow[]
  reminders     Reminder[]
  bookmarks     ChannelBookmark[]

  @@index([isPrivate, isDm])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  // Stored as AES-256-GCM ciphertext ("iv:tag:ciphertext", all base64).
  // Never store plaintext message bodies here.
  body      String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime? // soft-delete: row stays for thread integrity, body becomes tombstone on render

  // Threading: a reply points at its parent message.
  parentId String?
  parent   Message?  @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Message[] @relation("Thread")

  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadReads   ThreadRead[]
  reactions     Reaction[]
  attachments   Attachment[]
  notifications Notification[]
  reminders     Reminder[]
  savedBy       SavedMessage[]
  linkPreview   LinkPreview?
  pin           PinnedMessage?
  revisions     MessageRevision[]
  forwarded     ForwardedMessage?

  @@index([channelId, createdAt])
  @@index([parentId])
}

// A snapshot of a message forwarded into another channel. The forwarded
// message is a normal Message (its body is the forwarder's optional
// comment); this holds the embedded original — captured at forward time so
// rendering never needs access to the source channel (which the target
// audience may not have) and isn't affected by later edits/deletes of the
// original. `body` is ciphertext like any message content; sourceLabel is a
// plaintext channel name / "a direct message", not message content.
model ForwardedMessage {
  id                String   @id @default(cuid())
  messageId         String   @unique
  sourceLabel       String
  sourceIsDm        Boolean  @default(false)
  sourceAuthorName  String?
  body              String // ciphertext of the original message body
  originalCreatedAt DateTime
  createdAt         DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// A message composed now but delivered later. Body is AES-256-GCM ciphertext
// like a real message; the send is "replayed" at sendAt by the dispatcher
// (see POST /api/scheduled/dispatch), which runs it through the same
// deliverMessage() path a live send uses. parentId/attachmentIds/
// mentionedUserIds capture everything needed to reproduce the original
// compose. Terminal state is recorded by sentAt / canceledAt / failedAt.
model ScheduledMessage {
  id               String   @id @default(cuid())
  channelId        String
  userId           String
  body             String // ciphertext
  parentId         String? // thread root, if this was a scheduled reply
  attachmentIds    String[]
  mentionedUserIds String[]
  sendAt           DateTime
  createdAt        DateTime  @default(now())
  sentAt           DateTime?
  canceledAt       DateTime?
  failedAt         DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sendAt])
  @@index([userId, channelId])
}

// A prior version of an edited message, for edit-history transparency. On
// each edit the superseded body is snapshotted here BEFORE the message row
// is overwritten. Body is the same AES-256-GCM ciphertext the message
// stored (copied as-is, never decrypted+re-encrypted), so the at-rest
// guarantee carries over unchanged. `editedAt` is when that version was
// authored (the message's createdAt for the original, or the edit time for
// a later version).
model MessageRevision {
  id        String   @id @default(cuid())
  messageId String
  body      String // ciphertext of the superseded version
  editedAt  DateTime // when this version was authored
  createdAt DateTime @default(now()) // when the snapshot row was written

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model Attachment {
  id           String   @id @default(cuid())
  channelId    String // known before a message exists, needed for access checks
  messageId    String? // null until the message that references it is sent
  uploadedById String
  url          String // Vercel Blob URL — never sent to the client directly
  pathname     String // Blob pathname, for future del() support
  fileName     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message    Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([messageId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ---------------------------------------------------------------------------
// Read-state tracking, for unread indicators. One row per (scope, user).
// ---------------------------------------------------------------------------

model ChannelRead {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ThreadRead {
  id         String   @id @default(cuid())
  parentId   String
  userId     String
  lastReadAt DateTime @default(now())

  parent Message @relation(fields: [parentId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([parentId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// In-app notifications. No message preview is stored here — bodies are
// encrypted at rest, so the list endpoint decrypts the referenced Message
// fresh at read time instead of persisting a second plaintext copy.
// ---------------------------------------------------------------------------

enum NotificationType {
  MENTION
  DM
  THREAD_REPLY
  KEYWORD // a word from the recipient's keyword-alert list appeared
  CHANNEL // any message, for a channel the recipient set to "All"
  REMINDER // a self-scheduled "remind me about this message" (see Reminder)
}

// A "remind me about this message" — self-scheduled by a user. The dispatcher
// (POST /api/scheduled/dispatch) fires due reminders, materializing a
// REMINDER Notification that links back to the message. Cascades away if the
// message is deleted so we never remind about something that's gone.
model Reminder {
  id         String    @id @default(cuid())
  userId     String
  channelId  String
  messageId  String
  remindAt   DateTime
  createdAt  DateTime  @default(now())
  firedAt    DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([firedAt, remindAt])
  @@index([userId])
}

// A channel bookmark — a quick-access link pinned to the top of a channel
// (Slack's bookmarks bar). Any member can add one; the creator or an admin can
// remove it. Ordered by `position` for stable left-to-right display.
model ChannelBookmark {
  id          String   @id @default(cuid())
  channelId   String
  title       String
  url         String
  emoji       String? // optional leading emoji/token; falls back to a link glyph
  createdById String
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([channelId, position])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String // recipient
  actorId   String // who triggered it
  type      NotificationType
  channelId String
  messageId String
  parentId  String? // set for THREAD_REPLY, so the bell can link to the thread without joining Message
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor   User    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Unsent composer text, one per (channel, user) — root-channel composer
// only, not thread replies (see the visual-overhaul plan's scope note).
// Encrypted the same way messages are: this is message content that just
// hasn't been sent yet, so it gets the same at-rest guarantee.
// ---------------------------------------------------------------------------

model Draft {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  body      String // AES-256-GCM ciphertext, same shape as Message.body
  updatedAt DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model StarredChannel {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

// A link-unfurl preview for the first URL in a message — fetched
// asynchronously after send (see the messages POST route's after() call).
// Fields are AES-256-GCM ciphertext, same as Message.body: a preview's
// title/description reveal message content, so they get the same at-rest
// guarantee. One per message (unfurl only the first URL).
model LinkPreview {
  id          String   @id @default(cuid())
  messageId   String   @unique
  url         String // ciphertext
  title       String? // ciphertext
  description String? // ciphertext
  imageUrl    String? // ciphertext
  siteName    String? // ciphertext
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// A pinned message — shared/channel-level (unlike SavedMessage, which is
// personal). Any member can pin; the pin is visible to everyone in the
// channel. One pin per message.
model PinnedMessage {
  id         String   @id @default(cuid())
  messageId  String   @unique
  channelId  String
  pinnedById String
  createdAt  DateTime @default(now())

  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedBy User    @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

  @@index([channelId])
}

// "Later" — a personal flag on any message (root or reply) to come back to,
// same shape as StarredChannel but scoped to a message instead of a channel.
model SavedMessage {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Custom workspace emoji. Any member can add one (see POST /api/emoji). The
// image lives in Vercel Blob with PUBLIC access — unlike file attachments
// (private, proxied), custom emoji are intentionally workspace-wide display
// assets shown inline everywhere, not confidential content, so the Blob URL
// is used directly.
// ---------------------------------------------------------------------------
model CustomEmoji {
  id          String   @id @default(cuid())
  name        String   @unique // shortcode without colons, e.g. "partyparrot"
  url         String // private Blob URL — server-only, streamed via GET /api/emoji/:id
  pathname    String // Blob pathname, for delete()
  mimeType    String
  createdById String?
  createdAt   DateTime @default(now())

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

// Per-channel notification preference for one user. "muted" suppresses
// notifications AND the sidebar unread badge; "level" picks which message
// types notify when not muted (see the messages POST route's recipient
// resolution). Absent row = defaults (not muted, MENTIONS).
enum ChannelNotifyLevel {
  ALL // every message
  MENTIONS // @mentions, DMs, thread replies only (the app's original behavior)
  NONE // nothing
}

model ChannelPreference {
  id        String             @id @default(cuid())
  userId    String
  channelId String
  muted     Boolean            @default(false)
  level     ChannelNotifyLevel @default(MENTIONS)
  // Which custom sidebar section (if any) this user filed this channel under.
  // Null = the default "Channels" group. SetNull so deleting a section just
  // returns its channels to the default group rather than cascading.
  sectionId String?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  section ChannelSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([userId, channelId])
  @@index([userId])
}

// A Canvas — a titled rich-text doc ("create and share content"). Body is
// encrypted at rest like message bodies. Workspace-wide readable; editable by
// its creator (an admin can also delete).
model Canvas {
  id          String   @id @default(cuid())
  title       String
  body        String   @default("") // ciphertext (encryptMessage), may be empty
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([updatedAt])
}

// A List — a lightweight, collaborative project/task tracker ("track and
// manage projects"). Workspace-wide readable; any member can add/toggle/edit
// items; the creator (or an admin) can rename or delete the whole list.
model List {
  id          String   @id @default(cuid())
  title       String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User       @relation("CreatedLists", fields: [createdById], references: [id], onDelete: Cascade)
  items     ListItem[]

  @@index([updatedAt])
}

model ListItem {
  id         String    @id @default(cuid())
  listId     String
  text       String // ciphertext (encryptMessage)
  done       Boolean   @default(false)
  assigneeId String?
  dueAt      DateTime?
  position   Int       @default(0)
  createdAt  DateTime  @default(now())

  list     List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee User? @relation("AssignedItems", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([listId])
}

// A Workflow — a saved automation that auto-posts a message to a channel on a
// recurring schedule ("automate everyday tasks", e.g. a Monday standup nudge).
// The body is encrypted at rest like every message body; when a workflow fires
// it goes through the same deliverMessage() path as a live send, so it gets
// notifications, Pusher broadcast and unfurling identically. The scheduled-
// message dispatcher (POST /api/scheduled/dispatch) also advances and fires due
// workflows, so no separate cron is needed.
model Workflow {
  id          String @id @default(cuid())
  title       String
  channelId   String
  createdById String
  body        String // ciphertext (encryptMessage)

  // Recurrence. hour/minute are wall-clock in `timezone` (an IANA name, e.g.
  // "America/New_York") — nextRunAt is the resolved UTC instant, recomputed
  // across DST whenever the workflow fires or its schedule changes.
  frequency WorkflowFrequency
  dayOfWeek Int? // 0=Sun..6=Sat, set only when frequency = WEEKLY
  hour      Int // 0-23
  minute    Int // 0-59
  timezone  String

  enabled   Boolean   @default(true)
  nextRunAt DateTime // UTC instant of the next scheduled fire
  lastRunAt DateTime?
  runCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy User    @relation("CreatedWorkflows", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@index([updatedAt])
}

enum WorkflowFrequency {
  DAILY
  WEEKDAYS
  WEEKLY
}

// A user's custom sidebar section (personal — like Slack, sections organize
// your own view of shared channels, they aren't workspace-wide).
model ChannelSection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelPrefs ChannelPreference[]

  @@index([userId])
}

// User-global notification preferences: Do Not Disturb (snooze-until) and
// keyword alerts. One row per user, created on first change.
model NotificationPreference {
  id       String    @id @default(cuid())
  userId   String    @unique
  dndUntil DateTime? // notifications pushed to null/past = not snoozed
  keywords String[] // alert words: notify when any appears in a message

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
