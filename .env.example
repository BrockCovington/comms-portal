# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local — it is git-ignored on purpose.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ---------------------------------------------
# Use the "pooled" connection string from Neon for the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Use the "direct" (non-pooled) connection string for migrations / db push.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (NextAuth v5 / Auth.js) -----------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="REPLACE_ME"

# From Google Cloud Console (OAuth 2.0 Client ID — Web application).
AUTH_GOOGLE_ID="REPLACE_ME.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="REPLACE_ME"

# In production set this to your real URL, e.g. https://comms.yourcompany.com
# In local dev, this runs on 3001 (see package.json's dev/start scripts) so
# it doesn't collide with other local projects on 3000.
AUTH_URL="http://localhost:3001"

# --- Organization lock -----------------------------------------------------
# ONLY Google accounts on this Workspace domain may sign in.
# This is enforced server-side on every login. Example: yourcompany.com
ALLOWED_EMAIL_DOMAIN="yourcompany.com"

# --- Auto-admin on first sign-in (optional) --------------------------------
# Comma-separated, case-insensitive. Anyone signing in for the first time
# with one of these emails gets the ADMIN role immediately instead of the
# default EMPLOYEE — useful for bootstrapping admins who haven't signed in
# yet. Safe to leave empty; existing users are unaffected (this only fires
# on User row creation, i.e. someone's very first sign-in).
AUTO_ADMIN_EMAILS=""

# --- Message encryption at rest -------------------------------------------
# 32-byte key, base64-encoded. Generate with:  openssl rand -base64 32
# Message bodies are AES-256-GCM encrypted before being written to the DB.
# WARNING: if you lose/rotate this key, existing messages become unreadable.
MESSAGE_ENCRYPTION_KEY="REPLACE_ME"

# --- Workspace display name (cosmetic) ------------------------------------
NEXT_PUBLIC_WORKSPACE_NAME="Acme Inc."

# --- Rate limiting (optional) ----------------------------------------------
# Per-user rate limiting on sending messages, backed by Upstash Redis's REST
# API. Get these from an Upstash Redis database (upstash.com) — or, if
# provisioned via Vercel's KV marketplace add-on, use its KV_REST_API_URL /
# KV_REST_API_TOKEN values instead (Vercel KV is Upstash-backed and accepted
# under either name here).
# If neither pair is set, rate limiting is skipped entirely (fails open) —
# the app runs fine without this configured, just unprotected from spam.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- File & image uploads (required for that feature) -----------------------
# From a Vercel Blob store (vercel.com -> Storage -> Blob) — works whether or
# not the app itself is hosted on Vercel. Unlike rate limiting, there's no
# sensible degraded mode here: if this isn't set, uploads fail with a clear
# error rather than silently going nowhere.
BLOB_READ_WRITE_TOKEN=""

# --- Voice/video huddles (required for that feature) ------------------------
# From a LiveKit Cloud project (cloud.livekit.io) — API Key/Secret sign the
# join tokens minted server-side; the URL is the project's WebSocket
# endpoint, safe to expose to the client (it's just an address, not a
# credential). No sensible degraded mode here either: if unset, starting or
# joining a huddle fails with a clear error rather than connecting nowhere.
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
NEXT_PUBLIC_LIVEKIT_URL=""

# --- Scheduled messages & Workflows ----------------------------------------
# Secret guarding /api/scheduled/dispatch, which delivers due scheduled
# messages and fires due recurring Workflows. Generate with:
#   openssl rand -base64 32
# The Vercel Cron in vercel.json hits this endpoint every minute and, because
# this env var is named CRON_SECRET, Vercel automatically sends it as
# `Authorization: Bearer <CRON_SECRET>` — so just set the same value in Vercel.
# (An external scheduler can also POST here with the same bearer token.)
CRON_SECRET="REPLACE_ME"
